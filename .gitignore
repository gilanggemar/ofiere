# ========================================
# Hecate — .gitignore
# ========================================

# --- OpenClaw agent config (local only) ---
.openclaw/

# --- Audit data (local only) ---
.audit/
.audit

# --- Dependencies (auto-installed via npm install) ---
node_modules/
.pnp
.pnp.js
.pnp.cjs

# --- Next.js build output (auto-generated via npm run dev / npm run build) ---
.next/
out/
.turbo/

# --- Environment variables (contain secrets — NEVER commit) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Debug logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- TypeScript build info ---
*.tsbuildinfo
next-env.d.ts

# --- OS-generated files ---
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Phase backups (legacy development snapshots — not needed in repo) ---
.phase1/
.phase2/
.phase3/
.phase4/

# --- Legacy overview backups ---
.overview2/
.overview-redesign/
.old/

# --- Miscellaneous junk files ---
nul
backups.txt
recent_files.txt
task.md.resolved
task_plan.md
*.tmp
.tmp/
.backup/
NERV_CENTER_GAME_DESIGN*.md
. k i r o /  